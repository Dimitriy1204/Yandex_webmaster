# ============================================
# Yandex Wordstat API Agent
# ============================================

# API-ключ Яндекс.Облака для Search API (Wordstat)
# Как получить:
# 1. Перейдите: https://console.cloud.yandex.ru/
# 2. Создайте сервисный аккаунт или используйте существующий
# 3. Назначьте роль "search-api.admin" или "search-api.executor"
# 4. Создайте статический API-ключ (IAM)
# См. документацию: https://yandex.cloud/ru/docs/iam/operations/api-key/create
YANDEX_API_KEY=ваш_api_key_яндекс_облака

# Каталог в Яндекс.Облаке (folder ID)
# Можно узнать: https://console.cloud.yandex.ru/folders
FOLDER_ID=ваш_folder_id

# Поисковые запросы для анализа (через запятую)
# Пример: SEARCH_QUERIES=купить диван,заказать пиццу,доставка цветов
SEARCH_QUERIES=купить оборудование для,купить станок для,купить линию для,купить производство,купить комплекс

# ============================================
# Временной диапазон сбора статистики
# ============================================
# Формат: YYYY-MM (год-месяц, например 2022-01)
# from_date = 1-е число указанного месяца
# to_date   = последний день указанного месяца (API требует последний день месяца)
#
# ╔══════════════════════════════════════════════════════════════════╗
# ║  ВАЖНО про 2026 год:                                           ║
# ║  По умолчанию (если DATE_TO не указан) скрипт берёт последний  ║
# ║  полный месяц. Если вы хотите получить данные за 2026 год,     ║
# ║  просто укажите DATE_TO=2026-05 (или нужный месяц).            ║
# ║  Статистика в Wordstat доступна с задержкой ~1-2 месяца,       ║
# ║  поэтому текущий месяц может быть недоступен.                  ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Примеры:
#   DATE_FROM=2020-01  — с января 2020
#   DATE_TO=2026-06    — по июнь 2026 (включительно)
#
# Если не указывать (оставить пустыми):
#   DATE_FROM не указан → 2022-01-01 (январь 2022)
#   DATE_TO не указан   → последний полный месяц
#     (например: сегодня май 2026 → DATE_TO=2026-04)
#
# ВАЖНО: дата в to_date должна быть последним днём месяца.
# Скрипт сам подставит последний день. Вы пишете просто YYYY-MM.
#
# ╔══════════════════════════════════════════════════════════════════╗
# ║  РЕКОМЕНДАЦИИ ПО НАСТРОЙКЕ ДАТ:                                ║
# ║  • Для максимального периода: DATE_FROM=2018-01 (если нужно    ║
# ║    с 2018 года — если API отдаёт, скрипт возьмёт)              ║
# ║  • Для 2026 года укажите явно: DATE_TO=2026-05                 ║
# ║    (замените 05 на нужный месяц)                                ║
# ║  • Не ставьте DATE_TO на текущий месяц — API может             ║
# ║    вернуть неполные данные. Берите предыдущий полный месяц.    ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Раскомментируйте и укажите нужные даты:
# DATE_FROM=2022-01
# DATE_TO=2026-05
